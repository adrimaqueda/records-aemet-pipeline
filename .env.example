# Copia este archivo a `.env` (gitignored) y rellena los valores reales.

# Token JWT de https://opendata.aemet.es
AEMET_API_KEY=

# Dataset PÚBLICO de HuggingFace donde se publican los JSONs de la app
# (ej. tu-usuario/records-aemet)
EXTREMOS_HF_REPO=

# Dataset PRIVADO de HuggingFace para el backup de la DuckDB (ej. tu-usuario/records-aemet-db).
# Opcional: si lo dejas vacío, `extremos-backup` no hace nada.
EXTREMOS_HF_DB_REPO=

# Token con permisos WRITE en ambos repos (https://huggingface.co/settings/tokens).
# El de solo lectura sirve para el backfill desde datania, pero no para publicar.
HF_TOKEN=

# Aviso por Telegram con los récords batidos de cada pasada (extremos-notify).
# Opcionales: si se dejan vacíos se usa el bot del monitor de la Pi
# (/home/pi/docker/raspberry-monitor/.env) y, si tampoco existe, no se envía nada.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
